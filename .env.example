# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Секретный ключ для подписи cookie-сессий.
# Сгенерируй случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=38ed39c94a991e8d1a1461c449e2650d6da202526b50ed304d5f3fa5ae3521f0

# Секрет, которым подписываются входящие webhook-запросы от Albato.
# Albato должен передавать его в URL после ?secret=...
# Сгенерируй любую длинную случайную строку.
ALBATO_WEBHOOK_SECRET=38ed39c94a991e8d1a1461c449e2650d6da202526b50ed304d5f3fa5ae3521f0

# Логин/пароль админ-панели.
ADMIN_LOGIN=admin_topwb
ADMIN_PASSWORD=admin_topwb

# SMTP для писем подтверждения email.
# Пример для Яндекс 360: SMTP_HOST=smtp.yandex.ru, SMTP_PORT=465, SMTP_USE_TLS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Топай в ТОП
SMTP_USE_TLS=true

# Базовый URL сайта (без слэша в конце). Используется при формировании реф.ссылок.
PUBLIC_SITE_URL=https://www.toptopwb.ru

# Базовый URL личного кабинета (без слэша в конце).
LK_BASE_URL=https://referal-top-wb.ru

# Yandex SmartCaptcha. Ключ клиента виден на странице, ключ сервера хранить только в .env.
SMARTCAPTCHA_SITE_KEY=
SMARTCAPTCHA_SERVER_KEY=

# Процент комиссии партнёру от оплаченных сделок реферала (10 = 10%).
COMMISSION_PERCENT=10

# Путь к файлу базы. Оставь как есть для MVP.
DATABASE_PATH=./referal.db
